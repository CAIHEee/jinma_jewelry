# 应用名称，会显示在后端系统信息中。
APP_NAME=Flux Jewelry Design System

# 运行环境，常用值：development / production。
APP_ENV=development

# 后端监听地址与端口。
APP_HOST=0.0.0.0
APP_PORT=8000

# 是否开启调试模式。开发环境可设为 true，生产建议 false。
APP_DEBUG=true

# 允许跨域访问的固定来源，多个值用逗号分隔。
APP_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# 给五音等上游服务访问本机图片时使用的公开基地址，例如 https://your-domain.com 或 http://公网IP:端口。
APP_PUBLIC_BASE_URL=

# 允许跨域访问的来源正则。留空则按代码默认规则处理。
APP_ALLOWED_ORIGIN_REGEX=

# 默认生图服务提供方。当前仅保留 Gemini 与 Wuyin 两类上游。
AI_DEFAULT_PROVIDER=gemini

# 上游平台标识。当前项目默认使用 apiyi。
AI_UPSTREAM_PLATFORM=apiyi

# 多图融合或多参考图模块允许的最大参考图数量。
AI_MAX_FUSION_IMAGES=6

# 五音科技 GPT Image 2 中转密钥与参数。文生图默认模型会走这一套。
WUYIN_API_KEY=
WUYIN_BASE_URL=https://api.wuyinkeji.com
WUYIN_TIMEOUT_SECONDS=120
WUYIN_POLL_INTERVAL_SECONDS=3
WUYIN_POLL_ATTEMPTS=40

# APIYI 平台密钥。
APIYI_API_KEY=

# APIYI 基础地址。
APIYI_BASE_URL=https://api.apiyi.com
APIYI_OPENAI_BASE_URL=https://api.apiyi.com/v1
APIYI_GEMINI_BASE_URL=https://api.apiyi.com/v1beta

# AIAPIS GPT Image 2 中转。当前项目的 GPT Image 2 文生图、图生图、多图融合默认走这一套。
AIAPIS_API_KEY=
AIAPIS_BASE_URL=https://aiapis.help/v1
AIAPIS_TIMEOUT_SECONDS=300

# DMXAPI 图像编辑中转。当前用于 GPT Image 2 的图生图、多图融合等本地文件上传场景。
DMXAPI_API_KEY=
DMXAPI_BASE_URL=https://www.dmxapi.cn/v1
DMXAPI_TIMEOUT_SECONDS=180

# TTAPI 平台密钥。
TTAPI_API_KEY=

# TTAPI 各能力接口地址。
TTAPI_FLUX_BASE_URL=https://api.ttapi.io
TTAPI_OPENAI_BASE_URL=https://api.ttapi.org

# TTAPI 单次请求超时时间，单位秒。
TTAPI_TIMEOUT_SECONDS=120

# TTAPI 轮询间隔，单位秒。
TTAPI_POLL_INTERVAL_SECONDS=2.5

# TTAPI 轮询最大次数。数值越大，单任务等待上游结果的时间越长。
TTAPI_POLL_ATTEMPTS=24

# 数据库连接串。请替换为你的 MySQL 地址、账号和库名。
DATABASE_URL=mysql+pymysql://root:123456@192.168.10.150:3306/flux_system

# SQLAlchemy 连接池参数。
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE_SECONDS=3600

# 登录鉴权签名密钥。生产环境必须修改。
AUTH_SECRET_KEY=change-me-in-production

# Redis 地址。当前同时用于 RQ 任务队列和轻量缓存层。
QUEUE_REDIS_URL=redis://127.0.0.1:6379/0

# RQ 队列名称。
QUEUE_NAME=jinma-ai

# 单个任务最大执行时间，单位秒。
QUEUE_JOB_TIMEOUT_SECONDS=900

# RQ 任务结果在 Redis 中保留时间，单位秒。
QUEUE_RESULT_TTL_SECONDS=3600

# 普通用户允许同时处于 queued/running/uploading 状态的任务数。
QUEUE_USER_MAX_ACTIVE_JOBS=1

# root 用户允许同时处于 queued/running/uploading 状态的任务数。
QUEUE_ROOT_MAX_ACTIVE_JOBS=3

# 任务状态缓存保留时长，单位秒。前端轮询任务状态时优先读 Redis。
# 建议：开发环境 1800，内网生产 21600。
CACHE_JOB_STATUS_TTL_SECONDS=21600

# 重复提交去重缓存保留时长，单位秒。用于防止用户短时间重复点击提交。
# 建议：开发环境 60，内网生产 120。
CACHE_JOB_DEDUPE_TTL_SECONDS=120

# 模型列表缓存保留时长，单位秒。/api/v1/ai/models 会优先命中该缓存。
# 建议：开发环境 60，内网生产 300。
CACHE_MODEL_CATALOG_TTL_SECONDS=300

# 当前用户信息缓存保留时长，单位秒。/api/v1/auth/me 会优先命中该缓存。
# 建议：开发环境 30，内网生产 60。
CACHE_AUTH_ME_TTL_SECONDS=60

# 旧 OSS 兼容配置。当前单机本地存储方案下不是必填，只在你需要继续读取旧 oss:// 记录时才需要。
OSS_PROVIDER=aliyun

# 旧 OSS Bucket 与区域配置。仅旧数据兼容读取时使用。
OSS_BUCKET=oss-pai-r7x5470twdp2bxpuzk-cn-guangzhou
OSS_ENDPOINT=oss-cn-guangzhou.aliyuncs.com
OSS_REGION=oss-cn-guangzhou

# 旧 OSS 访问凭证。单机本地存储部署可以留空。
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

# 旧 OSS 签名 URL 有效期，单位秒。单机本地存储部署通常不会用到。
OSS_SIGNED_URL_EXPIRE_SECONDS=3600
