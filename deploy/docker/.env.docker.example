# Docker Compose 运行环境变量模板。
# 使用方式：复制为仓库根目录下的 .env.docker，然后用
# docker compose --env-file .env.docker up -d --build

# 时区，影响容器内日志和默认时间格式。
TZ=Asia/Shanghai

# nginx 对外暴露端口。
NGINX_PORT=80

# Docker Hub 镜像名。新机器默认从 Docker Hub 拉取这两个镜像。
BACKEND_IMAGE=your-dockerhub-username/jinma-backend:latest
NGINX_IMAGE=your-dockerhub-username/jinma-nginx:latest

# MySQL 初始化数据库名与 root 密码。
MYSQL_DATABASE=jinma
MYSQL_ROOT_PASSWORD=change-this-mysql-password

# Web API 使用的 gunicorn worker 数量。
WEB_CONCURRENCY=2

# 构建后端镜像时使用的 pip 源。离线包打包阶段下载 Python 依赖会用到。
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple

# CORS 来源配置。单机局域网部署可按实际访问地址填写。
APP_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
APP_ALLOWED_ORIGIN_REGEX=

# 应用鉴权密钥。生产环境必须修改。
AUTH_SECRET_KEY=change-this-auth-secret

# root 默认账号信息。首次启动时会按这组配置初始化。
ROOT_USERNAME=root
ROOT_DISPLAY_NAME=系统管理员
ROOT_EMAIL=root@example.com
ROOT_DEFAULT_PASSWORD=change-this-root-password

# AI 平台配置。至少填写你实际在用的一套。
AI_DEFAULT_PROVIDER=flux
AI_UPSTREAM_PLATFORM=apiyi
APIYI_API_KEY=
APIYI_BASE_URL=https://api.apiyi.com
APIYI_OPENAI_BASE_URL=https://api.apiyi.com/v1
APIYI_GEMINI_BASE_URL=https://api.apiyi.com/v1beta
TTAPI_API_KEY=
TTAPI_FLUX_BASE_URL=https://api.ttapi.io
TTAPI_OPENAI_BASE_URL=https://api.ttapi.org

# 上游调用与任务参数。
TTAPI_TIMEOUT_SECONDS=120
TTAPI_POLL_INTERVAL_SECONDS=2.5
TTAPI_POLL_ATTEMPTS=24
AI_MAX_FUSION_IMAGES=6
QUEUE_NAME=jinma-ai
QUEUE_JOB_TIMEOUT_SECONDS=900
QUEUE_RESULT_TTL_SECONDS=3600
QUEUE_USER_MAX_ACTIVE_JOBS=1
QUEUE_ROOT_MAX_ACTIVE_JOBS=3

# Redis 轻量缓存与任务状态缓存。
CACHE_JOB_STATUS_TTL_SECONDS=21600
CACHE_JOB_DEDUPE_TTL_SECONDS=120
CACHE_MODEL_CATALOG_TTL_SECONDS=300
CACHE_AUTH_ME_TTL_SECONDS=60

# 数据库连接池参数。
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE_SECONDS=3600
